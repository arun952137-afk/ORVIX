# ORVIX — Environment Variables
# Copy to .env.local and fill in values

# ─── App ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ORVIX

# ─── Database (Supabase) ───────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─── Supabase ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Clerk Auth ────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Stripe ────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_CREDITS_500_PRICE_ID=price_...
STRIPE_CREDITS_1000_PRICE_ID=price_...

# ─── Razorpay ──────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ─── OpenAI ────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# ─── Anthropic (Claude) ────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Gemini ─────────────────────
GOOGLE_AI_API_KEY=...

# ─── ElevenLabs ────────────────────────
ELEVENLABS_API_KEY=...

# ─── Stability AI ──────────────────────
STABILITY_API_KEY=...

# ─── Runway ────────────────────────────
RUNWAY_API_KEY=...

# ─── AssemblyAI ────────────────────────
ASSEMBLYAI_API_KEY=...

# ─── Deepgram ──────────────────────────
DEEPGRAM_API_KEY=...

# ─── Cloudflare R2 ─────────────────────
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=orvix-media
NEXT_PUBLIC_CDN_URL=https://cdn.orvix.io

# ─── Redis ─────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=...

# ─── Email ─────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...
FROM_EMAIL=noreply@orvix.io

# ─── Encryption ────────────────────────
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ─── Feature Flags ─────────────────────
NEXT_PUBLIC_ENABLE_VOICE_CLONE=true
NEXT_PUBLIC_ENABLE_4K_EXPORT=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
